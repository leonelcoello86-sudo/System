# Backend - variables requeridas para correr en local y Render

# MongoDB Atlas
MONGODB_URI=

# JWT
# En producción, usa un secret de al menos 64 caracteres de alta entropía.
# Nunca commitees este valor. En Render, configúralo como variable de entorno.
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Seed del admin (se crea si no existe)
ADMIN_EMAIL=admin@comando.mil.ve
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Puerto (opcional)
PORT=5000

# CORS (opcional)
# Sepáralo por comas si hay más de un origen.
# En Render típicamente usa el dominio del frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
